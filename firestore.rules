rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicit collection rules to prevent any permission issues in development preview
    match /students/{docId} {
      allow read, write: if true;
    }
    match /teachers/{docId} {
      allow read, write: if true;
    }
    match /onlineAdmissions/{docId} {
      allow read, write: if true;
    }
    match /results/{docId} {
      allow read, write: if true;
    }
    match /sessions/{docId} {
      allow read, write: if true;
    }
    match /courses/{docId} {
      allow read, write: if true;
    }
    match /settings/{docId} {
      allow read, write: if true;
    }
    match /attendance/{docId} {
      allow read, write: if true;
    }
    match /fees/{docId} {
      allow read, write: if true;
    }
    match /events/{docId} {
      allow read, write: if true;
    }
    match /users/{docId} {
      allow read, write: if true;
    }

    // Global wildcard fallback
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
